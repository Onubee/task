# База данных
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=testdb
DB_SSLMODE=disable

# Сервер
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Источники
PRODUCTS_URL_PATTERN=https://api.dynamica.space/sources/source%d.php
CLIENTS_URL=https://api.dynamica.space/sources/clients.php

# Диапазон источников
PRODUCTS_SOURCES_RANGE=1-3

# Пагинация
PAGE_START=1
PAGE_LIMIT=50
MAX_PAGES=100

# Конкурентность
MAX_CONCURRENT_REQUESTS=5
RATE_LIMIT=10
BURST_SIZE=5
REQUEST_DELAY=100ms

# Загрузка
DOWNLOAD_TIMEOUT=30s
MAX_RETRIES=3
RETRY_DELAY=1s

# Логирование
LOG_LEVEL=info